Panels:
  - Class: rviz/Displays
    Help Height: 70
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /TF1/Frames1
        - /TF1/Tree1
        - /Destinations1
        - /Destinations1/UAV11
        - /Destinations1/UAV31
        - /Encumbrances1/UAV61
        - /Encumbrances1/UAV71
        - /Encumbrances1/UAV81
        - /Encumbrances1/UAV91
        - /Encumbrances1/UAV101
        - /Marker1
        - /PoseArray1
        - /PointCloud24
        - /PointCloud25
        - /PointCloud26
        - /Marker12
        - /PointCloud28
      Splitter Ratio: 0.560869574546814
    Tree Height: 650
  - Class: rviz/Selection
    Name: Selection
  - Class: rviz/Tool Properties
    Expanded:
      - /2D Pose Estimate1
      - /2D Nav Goal1
      - /Publish Point1
    Name: Tool Properties
    Splitter Ratio: 0.5886790156364441
  - Class: rviz/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
  - Class: rviz/Time
    Name: Time
    SyncMode: 0
    SyncSource: PointCloud2
Preferences:
  PromptSaveOnExit: true
Toolbars:
  toolButtonStyle: 2
