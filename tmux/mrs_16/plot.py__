    #         ax.plot([x1, x2], [y1, y2], color='gray', linestyle='--', linewidth=5)

# Choose the three time points to plot circles:
# start, mid, and final positions
    # num_points = len(df.groupby("field.child_frame_id").first())
    num_points = max(len(g) for _, g in df.groupby("field.child_frame_id"))
    print(num_points)
    # time_indices = [0, 550, 1000, 1400]

    # start_idx = 0
    time_indices = [0, 550-200,  1000-200,  1425-200]
# Plot filled circles and lattice at those times
    plot_lattice(ax, df, time_indices, circle_radius=0.2, distance_threshold=4.1)



    groups = df.groupby("field.child_frame_id")

    # Plot UAV trajectories as 1-meter-wide tubes
    colors = plt.cm.get_cmap("tab10")
    for i, (uav, g) in enumerate(groups):
        draw_path_with_width(
            ax,
            g["field.pose.pose.position.x"].values,
