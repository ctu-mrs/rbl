def main(csv_file, launch_file):
    # --- Load UAV trajectory CSV ---
    df = pd.read_csv(csv_file)
    start_idx= find_start_index(df, velocity_threshold=0.2)-10
    print("start",start_idx)
    



# idx_start is the index in a single UAV trajectory
    idx_start = start_idx  

# pick a reference UAV (first one)
    uav0, g0 = next(iter(df.groupby("field.child_frame_id")))

# get its timestamps
    t = g0["field.header.stamp"].values
    t = np.where(t > 1e12, t * 1e-9, t)

# convert idx_start → physical start time
    t_start = t[idx_start]

# normalize ALL timestamps
    t_all = df["field.header.stamp"].values
    t_all = np.where(t_all > 1e12, t_all * 1e-9, t_all)

# filter DataFrame by time
    df = df[t_all >= t_start].reset_index(drop=True)








    required_cols = [
        "field.child_frame_id",
        "field.pose.pose.position.x",
        "field.pose.pose.position.y"
    ]
    for col in required_cols:
        if col not in df.columns:
            raise ValueError(f"Missing column in CSV: {col}")

    # --- Parse obstacles from launch file ---
    ox, oy = parse_launch_obstacles(launch_file)

    plot_trajectories_and_obstacles(df, ox, oy, obstacle_radius=0.15, path_width=0.4)

    # plot_distances_in_time(df, distance_threshold=4.1)
    # plot_distances_in_time(df, distance_threshold=4.1)

    # --- Plot ---
    # plt.rcParams.update({
    #     "text.usetex": True,
    #     "pgf.texsystem": "pdflatex",
    #     "font.family": "serif",
    #     "font.size": 10,
    # })

    plt.savefig('traj.pdf')
    plt.show()
















