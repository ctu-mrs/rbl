<launch>
    <arg name="UAV_NAME" default="$(optenv UAV_NAME)" />
    <arg name="map_frame" default="world" />
    <arg name="map_size_x" default="20" />
    <arg name="map_size_y" default="20" />
    <arg name="map_size_z" default="4" />
    <arg name="map_resolution" value="0.1"/>
    <arg name="map_obs_num" default="5"/>
    <arg name="map_circle_num" default="0"/>

    <arg name="ObstacleShape_seed" value="1"/>
    <arg name="ObstacleShape_lower_rad" value="0.5"/>
    <arg name="ObstacleShape_upper_rad" value="1.0"/>
    <arg name="ObstacleShape_lower_hei" value="0.05"/>
    <arg name="ObstacleShape_upper_hei" value="0.06"/>
    <!-- <arg name="ObstacleShape_lower_hei" value="10.0"/> -->
    <!-- <arg name="ObstacleShape_upper_hei" value="10.0"/> -->

    <arg name="ObstacleShape_radius_l" value="0.7"/>
    <arg name="ObstacleShape_radius_h" value="0.5"/>
    <arg name="ObstacleShape_z_l" value="0.7"/>
    <arg name="ObstacleShape_z_h" value="0.8"/>
    <arg name="ObstacleShape_theta" value="0.5"/>

    <arg name="rate_map_pub" value="1.0"/>
    <arg name="min_dist" value="0.0"/>

    <node pkg ="map_generator" name ="random_forest" type ="random_forest" output = "screen">
        <param name="frame_id" value="$(arg map_frame)"/>
        <param name="map/x_size" value="$(arg map_size_x)" />
        <param name="map/y_size" value="$(arg map_size_y)" />
        <param name="map/z_size" value="$(arg map_size_z)" />
        <param name="map/resolution" value="$(arg map_resolution)"/>
        <param name="map/circle_num" value="$(arg map_circle_num)"/>
        <param name="map/obs_num" value="$(arg map_obs_num)"/>

        <param name="ObstacleShape/seed" value="$(arg ObstacleShape_seed)"/>
        <param name="ObstacleShape/lower_rad" value="$(arg ObstacleShape_lower_rad)"/>
        <param name="ObstacleShape/upper_rad" value="$(arg ObstacleShape_upper_rad)"/>
        <param name="ObstacleShape/lower_hei" value="$(arg ObstacleShape_lower_hei)"/>
        <param name="ObstacleShape/upper_hei" value="$(arg ObstacleShape_upper_hei)"/>

        <param name="ObstacleShape/radius_l" value="$(arg ObstacleShape_radius_l)"/>
        <param name="ObstacleShape/radius_h" value="$(arg ObstacleShape_radius_h)"/>
        <param name="ObstacleShape/z_l" value="$(arg ObstacleShape_z_l)"/>
        <param name="ObstacleShape/z_h" value="$(arg ObstacleShape_z_h)"/>
        <param name="ObstacleShape/theta" value="$(arg ObstacleShape_theta)"/>

        <param name="pub_rate" value="$(arg rate_map_pub)"/>
        <param name="min_distance" value="$(arg min_dist)"/>
    </node>
</launch>
